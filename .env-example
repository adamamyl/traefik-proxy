# Traefik reverse proxy configuration
# Copy to .env and fill in values.

# ACME / Let's Encrypt email address
ACME_EMAIL=hostmaster@adamamyl.com

# Certificate resolver to use globally.
# lestaging = Let's Encrypt staging (safe for testing, certs not browser-trusted)
# leprod    = Let's Encrypt production (switch once staging verified)
CERT_RESOLVER=lestaging

# Traefik dashboard domain (must be a real domain routable to this host)
TRAEFIK_DOMAIN=traefik.wolfcraig.amyl.org.uk

# ── Local dev TLS (laptop only, docker-compose.localhost.yml) ─────────────────

# Root CA cert validity for step-ca. 330 days (7920h) keeps browsers happy.
# Changing this only takes effect after deleting the step_ca_data volume.
CA_CERT_DURATION=7920h

# Optional: pin the step-ca provisioner password. Auto-generated if blank.
# If set, store in 1Password and reference via op run -- docker compose up
# STEP_CA_PASSWORD=
